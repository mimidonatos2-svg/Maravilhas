rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the authenticated user is the owner admin or in the admin collection
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'donato01041957@gmail.com' ||
        exists(/databases/$(database)/documents/administradores/$(request.auth.uid))
      );
    }

    // Administradores
    match /administradores/{adminId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'donato01041957@gmail.com';
    }

    // Versículo do Dia
    match /versiculo/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações da Rádio
    match /radio/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações da TV
    match /tv/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Programação da Rádio
    match /programacao/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deus Para Você (Vídeos)
    match /deus_para_voce/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Podcasts
    match /podcasts/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos de Oração (público pode criar e ler, admin pode gerenciar)
    match /pedidos_oracao/{document} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Oração e Palavra (Devocionais/Estudos)
    match /palavra/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Doações
    match /doacoes/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Redes Sociais
    match /redes_sociais/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notificações Push
    match /notificacoes/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
